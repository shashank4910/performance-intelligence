# =============================================================================
# Performance Intelligence — environment variables
# =============================================================================
# Copy to .env.local for local development. Never commit real values.
# On Vercel: set these in Project → Settings → Environment Variables.
# Keys with NEXT_PUBLIC_ prefix are exposed to the browser; do not add secrets.
# =============================================================================

# --- Required ---------------------------------------------------------------

# Postgres connection string (e.g. Supabase). Prisma reads this at runtime.
# Vercel: set for Production, Preview, and Development.
DATABASE_URL=

# NextAuth signing secret. Generate with: openssl rand -base64 32
# Vercel: set for Production, Preview, and Development.
NEXTAUTH_SECRET=

# --- Optional but strongly recommended -------------------------------------

# Google PageSpeed Insights API key. Used by /api/analyze, /api/compare,
# /api/competitive-intelligence, and the competitor engine. Without it those
# routes fall back to limited / degraded output.
PAGESPEED_API_KEY=
# Alternate name checked after PAGESPEED_API_KEY — set either one.
GOOGLE_API_KEY=

# OpenAI API key. Used by the narrative / executive summary / metric
# explanation routes. When unset, all those routes fall back to deterministic
# copy — the app still works, just without AI-written prose.
OPENAI_API_KEY=

# --- Optional --------------------------------------------------------------

# Absolute URL NextAuth uses to build callbacks. Set on Vercel Production:
# NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_URL=

# --- Development-only flags (DO NOT set in Vercel production) --------------

# Set to 1 locally to include executive_summary_debug (RAW_AI_SUMMARY vs
# FINAL_SUMMARY) on /api/analyze responses. MUST remain unset in production.
EXEC_SUMMARY_DEBUG=
