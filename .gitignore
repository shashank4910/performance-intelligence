# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# Cursor MCP (may contain API keys)
.cursor/mcp.json
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# Lighthouse run caches (Chrome profile data, 30+ MB — never commit)
.lighthouse-tmp/

# Ad-hoc Lighthouse / PageSpeed JSON dumps in repo root
/lighthouse-*.json
/psi-*.json

# Cursor session artifacts (debug logs, scratch analyses)
.cursor/debug-*.log
.cursor/flipkart-*.json
